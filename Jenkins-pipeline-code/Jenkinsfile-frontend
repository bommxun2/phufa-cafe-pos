pipeline {
    agent any

    parameters {
        string(name: 'API_URL', defaultValue: '', description: 'URL of API GATEWAY')
        string(name: 'S3_BUCKET_NAME', defaultValue: '', description: 'S3 bucket name')
    }

    tools {
        nodejs 'nodejs'
    }
    
    stages {
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/bommxun2/phufa-cafe-pos.git'
            }
        }
        stage("Environment Variables") {
            steps {
                dir("frontend") {
                    sh "echo 'NEXT_PUBLIC_API_BASE_URL =${params.API_URL}' > .env"
                }
            }
        }
        stage("Install Dependencies and Build") {
            steps {
                dir("frontend") {
                    sh "npm ci"
                    sh "npm run build"
                }
            }
        }
        stage("Sync files to S3") {
            steps {
                withAWS(credentials: 'aws-key', region: 'us-east-1') {
                    dir("frontend") {
                        sh "aws s3 sync dist/ s3://${params.S3_BUCKET_NAME} --delete"
                    }
                }
            }
        }
    }
}